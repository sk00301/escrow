# ── Server ─────────────────────────────────────────────────────────────────────
APP_ENV=development
PORT=8001

# ── Database ───────────────────────────────────────────────────────────────────
# Dev  (SQLite  — zero setup):
DATABASE_URL=sqlite+aiosqlite:///./governance.db
# Prod (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/governance

# ── Blockchain ─────────────────────────────────────────────────────────────────
ALCHEMY_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
ESCROW_CONTRACT_ADDRESS=0xYOUR_ESCROW_CONTRACT_ADDRESS

# ── Governance rules (all optional — these are the defaults) ───────────────────
VOTING_DAYS=7
QUORUM=10
MAX_ACTIVE_PROPOSALS=2
