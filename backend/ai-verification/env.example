# ══════════════════════════════════════════════════════════════════════════════
#  AI Verification Service — Environment Configuration Template
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to git. This template (.env.example) is safe to commit.
# ══════════════════════════════════════════════════════════════════════════════

# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=development                  # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=DEBUG                      # DEBUG | INFO | WARNING | ERROR

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Blockchain / Oracle ────────────────────────────────────────────────────────
# WARNING: Never use a wallet with real funds. Sepolia testnet only.
ORACLE_PRIVATE_KEY=0xYOUR_ORACLE_WALLET_PRIVATE_KEY_HERE

# Deployed contract addresses on Sepolia testnet
ESCROW_CONTRACT_ADDRESS=0xYOUR_ESCROW_CONTRACT_ADDRESS
EVIDENCE_REGISTRY_ADDRESS=0xYOUR_EVIDENCE_REGISTRY_ADDRESS
DISPUTE_CONTRACT_ADDRESS=0xYOUR_DISPUTE_CONTRACT_ADDRESS

# Sepolia RPC — get free key at alchemy.com or infura.io
ALCHEMY_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
# INFURA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID  # alternative

CHAIN_ID=11155111                    # Sepolia chain ID

# ── IPFS / Pinata ──────────────────────────────────────────────────────────────
PINATA_API_KEY=YOUR_PINATA_API_KEY
PINATA_SECRET_KEY=YOUR_PINATA_SECRET_KEY
PINATA_GATEWAY=https://gateway.pinata.cloud

# ── AI Scoring Thresholds ──────────────────────────────────────────────────────
# Scores below AMBIGUITY_BAND_LOW  → REJECTED  (oracle posts rejection)
# Scores in  [AMBIGUITY_BAND_LOW, AMBIGUITY_BAND_HIGH] → DISPUTED (jury triggered)
# Scores above APPROVAL_THRESHOLD  → APPROVED  (payment released)
AMBIGUITY_BAND_LOW=0.45
AMBIGUITY_BAND_HIGH=0.75
APPROVAL_THRESHOLD=0.75

# Score component weights (must sum to 1.0)
WEIGHT_TEST_PASS=0.50                # Automated pytest results
WEIGHT_STATIC_ANALYSIS=0.25         # pylint / flake8 score
WEIGHT_COMPLEXITY=0.15              # Cyclomatic complexity (radon)
WEIGHT_SEMANTIC=0.10                # Semantic similarity to requirements

# ── Task Queue (Celery + Redis) ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite for prototype — change to PostgreSQL for production
DATABASE_URL=sqlite+aiosqlite:///./verification_jobs.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ai_verification

# ── Docker Sandbox ─────────────────────────────────────────────────────────────
DOCKER_SANDBOX_IMAGE=python:3.11-slim
DOCKER_TIMEOUT_SECONDS=30           # Max execution time per sandbox container
DOCKER_MEMORY_LIMIT=256m            # Memory cap per container
DOCKER_CPU_PERIOD=100000
DOCKER_CPU_QUOTA=50000              # 50% of one CPU core

# ── GitHub Integration (optional) ─────────────────────────────────────────────
# GITHUB_TOKEN=ghp_YOUR_TOKEN       # Increases rate limit from 60 to 5000 req/hr

# ── Security ───────────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
