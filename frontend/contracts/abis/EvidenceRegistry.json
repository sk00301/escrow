{
  "contractName": "EvidenceRegistry",
  "abi": [
    {
      "type": "constructor",
      "inputs": [{ "name": "_escrowContract", "type": "address" }],
      "stateMutability": "nonpayable"
    },
    {
      "type": "function",
      "name": "registerEvidence",
      "inputs": [
        { "name": "milestoneId",  "type": "uint256" },
        { "name": "contentHash",  "type": "bytes32" },
        { "name": "ipfsCID",      "type": "string"  },
        { "name": "submitter",    "type": "address" }
      ],
      "outputs": [],
      "stateMutability": "nonpayable"
    },
    {
      "type": "function",
      "name": "getEvidence",
      "inputs": [{ "name": "milestoneId", "type": "uint256" }],
      "outputs": [
        { "name": "contentHash", "type": "bytes32" },
        { "name": "ipfsCID",     "type": "string"  },
        { "name": "submitter",   "type": "address" },
        { "name": "timestamp",   "type": "uint256" }
      ],
      "stateMutability": "view"
    },
    {
      "type": "function",
      "name": "verifyIntegrity",
      "inputs": [
        { "name": "milestoneId", "type": "uint256" },
        { "name": "checkHash",   "type": "bytes32" }
      ],
      "outputs": [{ "name": "", "type": "bool" }],
      "stateMutability": "view"
    },
    {
      "type": "function",
      "name": "hasEvidence",
      "inputs": [{ "name": "milestoneId", "type": "uint256" }],
      "outputs": [{ "name": "", "type": "bool" }],
      "stateMutability": "view"
    },
    {
      "type": "function",
      "name": "escrowContract",
      "inputs": [],
      "outputs": [{ "name": "", "type": "address" }],
      "stateMutability": "view"
    },
    {
      "type": "event",
      "name": "EvidenceRegistered",
      "inputs": [
        { "name": "milestoneId",  "type": "uint256", "indexed": true  },
        { "name": "contentHash",  "type": "bytes32", "indexed": true  },
        { "name": "ipfsCID",      "type": "string",  "indexed": false },
        { "name": "submitter",    "type": "address", "indexed": true  },
        { "name": "timestamp",    "type": "uint256", "indexed": false }
      ]
    }
  ]
}
